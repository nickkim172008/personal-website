# Copy this file to .env.local and fill in real values. .env.local is
# git-ignored and is only ever read on the server (see lib/hevy.ts and
# lib/spotify.ts) — these values are never sent to the browser.

# Hevy API — powers the Training card on the About section.
# Get your API key from the Hevy app: Profile -> Settings -> Developer.
# If unset, the Training card shows deterministic placeholder data.
HEVY_API_KEY=

# Spotify Web API — powers the "Now playing" card on the About section.
# Create an app at https://developer.spotify.com/dashboard to get a client
# ID/secret, then complete the Authorization Code flow once (with the
# user-read-currently-playing and user-read-recently-played scopes) to obtain
# a refresh token. If any of these are unset, the card shows placeholder data.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
